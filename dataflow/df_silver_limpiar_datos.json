				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source6",
				"srcefectivos derive(nombre = trim(upper(nombre)),",
				"          ci = trim(ci),",
				"          genero = case(   upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'MASCULINO' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'MASC' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'M' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'HOMBRE' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'H', 'MASCULINO',   upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'FEMENINO' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'FEM' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'F' ||    upper(trim(regexReplace(genero, '[^A-Za-z]', ''))) == 'MUJER', 'FEMENINO',   'NO ESPECIFICADO' ),",
				"          departamento_origen = case(   in(['LA PAZ','LAPAZ','LP','L.P.','LA  PAZ'], upper(trim(departamento_origen))), 'LA PAZ',   in(['COCHABAMBA','CBBA','CBBA.','CBBA'], upper(trim(departamento_origen))), 'COCHABAMBA',   in(['SANTA CRUZ','SCZ','SC','STA. CRUZ','STA CRUZ','STA.CRUZ'], upper(trim(departamento_origen))), 'SANTA CRUZ',   in(['ORURO','OR','OR.'], upper(trim(departamento_origen))), 'ORURO',   in(['POTOSI','POTOSI'], upper(trim(departamento_origen))), 'POTOSI',   in(['TARIJA','TJ','TJ.'], upper(trim(departamento_origen))), 'TARIJA',   in(['BENI','BN','BN.'], upper(trim(departamento_origen))), 'BENI',   in(['PANDO','PN','PN.','PT','PT.'], upper(trim(departamento_origen))), 'PANDO',   in(['CHUQUISACA','CHQ','CHQ.','SUCRE'], upper(trim(departamento_origen))), 'CHUQUISACA',   'NO ESPECIFICADO' ),",
				"          estado = trim(upper(estado)),",
				"          fecha_nacimiento = toDate(fecha_nacimiento),",
				"          fecha_ingreso = toDate(fecha_ingreso),",
				"          salario_mensual = toDecimal(salario_mensual)) ~> cleanefectivos",
				"srcMovimientosPersonal derive(observaciones = trim(upper(observaciones)),",
				"          fecha_movimiento = toDate(fecha_movimiento),",
				"          antiguedad_anios = toInteger(antiguedad_anios),",
				"          salario_mensual = toDecimal(salario_mensual)) ~> cleanmovimientospersonal",
				"srroperacon derive(nombre_operacion = trim(upper(nombre_operacion)),",
				"          fecha_inicio = toDate(fecha_inicio),",
				"          fecha_fin = toDate(fecha_fin),",
				"          efectivos_desplegados = toInteger(efectivos_desplegados),",
				"          vehiculos_utilizados = toInteger(vehiculos_utilizados),",
				"          duracion_dias = toInteger(duracion_dias),",
				"          costo_operacion = toDecimal(costo_operacion),",
				"          detenidos = toInteger(detenidos),",
				"          area_km2 = toDecimal(area_km2),",
				"          resultado = case(   in(['COMPLETADA','CONCLUIDA','FINALIZADA','EXITOSA','EXITOSO','EXITO','SI, EXITOSA','OBJETIVO CUMPLIDO','LOGRADO','SATISFACTORIO','FAVORABLE','RESULTADO POSITIVO','POSITIVO','BUENO','MUY BUENO','ACEPTABLE','REGULAR'], upper(trim(resultado))), 'EXITOSA',   in(['FALLIDA','NEGATIVO','SIN EXITO','INCONCLUSA','INCOMPLETA','NO LOGRADO','SIN RESULTADOS','SIN RESULTADOS CONCRETOS'], upper(trim(resultado))), 'FALLIDA',   in(['EN PROCESO','EN CURSO','PARCIAL','PARCIALMENTE EXITOSA','PARCIALMENTE EXITOSO','PARCIALMENTE LOGRADO','PENDIENTE DE EVALUACION','POR EVALUAR'], upper(trim(resultado))), 'EN PROCESO',   'NO REPORTADO' )) ~> cleanop",
				"srzonas derive(nombre = trim(upper(nombre)),",
				"          departamento = trim(upper(departamento)),",
				"          frontera_con = trim(upper(frontera_con)),",
				"          tipo_terreno = trim(upper(tipo_terreno)),",
				"          nivel_riesgo = trim(upper(nivel_riesgo)),",
				"          altitud_msnm = toInteger(altitud_msnm)) ~> cleanzonas",
				"source1 derive(nombre = trim(upper(nombre)),",
				"          categoria = trim(upper(categoria)),",
				"          abreviatura = trim(upper(abreviatura))) ~> cleanrangos",
				"source2 derive(nombre = trim(upper(nombre)),",
				"          area = trim(upper(area))) ~> derivedColumn1",
				"source3 derive(nombre = trim(upper(nombre)),",
				"          descripcion = trim(upper(descripcion))) ~> derivedColumn2",
				"source4 derive(nombre = trim(upper(nombre)),",
				"          categoria = trim(upper(categoria))) ~> derivedColumn3",
				"source5 derive(nombre = trim(upper(nombre)),",
				"          codigo = trim(upper(codigo)),",
				"          ciudad = trim(upper(ciudad)),",
				"          departamento = trim(upper(departamento)),",
				"          tipo_cuartel = trim(upper(tipo_cuartel))) ~> derivedColumn4",
				"source6 derive(nivel = trim(upper(nivel)),",
				"          nombre = trim(upper(nombre)),",
				"          sigla = trim(upper(sigla)),",
				"          tipo = trim(upper(tipo)),",
